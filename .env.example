# Copy to .env and fill only the keys for the services you use.

# Dashboard cookie signing secret.
# Generate with:
# python -c "import secrets; print(secrets.token_hex(32))"
DASHBOARD_SECRET_KEY=

# LLM provider. Default is Ollama so the repo can run locally without paid API keys.
# Options: ollama, claude, openai, gemini, groq
LLM_PROVIDER=ollama

# Local LLM config
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Hosted LLM keys. Leave blank unless that provider is selected.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# Optional model overrides
ANTHROPIC_MODEL=claude-opus-4-6
OPENAI_MODEL=gpt-4o
GEMINI_MODEL=gemini-2.0-flash
GROQ_MODEL=llama-3.3-70b-versatile

# Alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Paper trading
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
